# ============================================================
# Editors / IDEs
# ============================================================
# VSCode — keep .vscode folder out by default; uncomment specific
# files below if you want to share them with the team
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json

.idea/
*.swp
*.swo
*~

